// Litmus starter — a clean Codespace for building your own test solution.
//
// This repo is NOT the Litmus source. It's a template: click
//   Use this template ▸ Create codespace
// and you get a fresh workspace with litmus-test installed and a starter
// project scaffolded against mock instruments. No local install, no hardware.
//
// Nothing Litmus-specific is committed here — the starter is generated at
// create time by the same version of litmus-test that was just installed,
// so it never drifts from the release.
{
  "name": "Litmus starter",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // Install the latest published Litmus, then scaffold a Tier-2 starter
  // project INTO THE WORKSPACE ROOT (no name = current dir, like `uv init`).
  // --no-git: the workspace is already a git repo, don't nest another.
  "postCreateCommand": "pip install --upgrade pip && pip install litmus-test && litmus init --starter --no-git",

  // The operator UI starts automatically via a folderOpen VS Code task
  // (.vscode/tasks.json) that runs `litmus serve` in a visible terminal —
  // so it's running on open, and you can see the exact command.
  //
  // The operator UI runs on 8000; auto-forward and pop the in-editor preview.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Litmus Operator UI",
      "onAutoForward": "openPreview"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff"]
    },
    // Open the in-codespace welcome page automatically on first start.
    "codespaces": {
      "openFiles": ["WELCOME.md"]
    }
  },

  // Printed in the terminal each time you attach.
  "postAttachCommand": "printf '\\n\\xF0\\x9F\\xA7\\xAA  Litmus starter. The operator UI auto-starts in the editor (litmus serve) and opens in a tab.\\n\\n  pytest                         # run the tests (mock instruments)\\n  See WELCOME.md for the 30-second tour.\\n\\nHeadless (no editor)? Start the UI yourself:  litmus serve --host 0.0.0.0\\n\\n'"
}
